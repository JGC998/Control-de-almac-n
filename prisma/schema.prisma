generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Cliente {
  id           String        @id @default(uuid())
  nombre       String        @unique
  email        String?
  direccion    String?
  telefono     String?
  tier         String?
  categoria    String?
  pedidos      Pedido[]
  presupuestos Presupuesto[]

  @@index([email])
}

model Fabricante {
  id        String     @id @default(uuid())
  nombre    String     @unique
  productos Producto[]
}

model Material {
  id        String     @id @default(uuid())
  nombre    String     @unique
  productos Producto[]
}

model Pedido {
  id            String   @id @default(uuid())
  numero        String   @unique
  fechaCreacion DateTime @default(now())
  estado        String
  notas         String?
  subtotal      Float
  tax           Float
  total         Float
  clienteId     String?
  presupuestoId String?  @unique
  marginId      String?

  cliente     Cliente?     @relation(fields: [clienteId], references: [id])
  presupuesto Presupuesto? @relation(fields: [presupuestoId], references: [id])
  items       PedidoItem[]

  @@index([clienteId])
  @@index([estado])
  @@index([fechaCreacion])
}

model PedidoItem {
  id               String  @id @default(uuid())
  descripcion      String
  quantity         Int
  unitPrice        Float
  pesoUnitario     Float   @default(0)
  detallesTecnicos String?
  pedidoId         String
  productoId       String?

  pedido   Pedido    @relation(fields: [pedidoId], references: [id], onDelete: Cascade)
  producto Producto? @relation(fields: [productoId], references: [id], onDelete: SetNull)
}

model Presupuesto {
  id            String   @id @default(uuid())
  numero        String   @unique
  fechaCreacion DateTime @default(now())
  estado        String
  notas         String?
  subtotal      Float
  tax           Float
  total         Float
  clienteId     String?
  marginId      String?

  cliente Cliente?          @relation(fields: [clienteId], references: [id])
  items   PresupuestoItem[]
  pedido  Pedido?

  @@index([clienteId])
  @@index([estado])
  @@index([fechaCreacion])
}

model PresupuestoItem {
  id               String  @id @default(uuid())
  descripcion      String
  quantity         Int
  unitPrice        Float
  pesoUnitario     Float   @default(0)
  detallesTecnicos String?
  presupuestoId    String
  productoId       String?

  presupuesto Presupuesto @relation(fields: [presupuestoId], references: [id], onDelete: Cascade)
  producto    Producto?   @relation(fields: [productoId], references: [id], onDelete: SetNull)
}

model Proveedor {
  id        String            @id @default(uuid())
  nombre    String            @unique
  email     String?
  telefono  String?
  direccion String?
  pedidos   PedidoProveedor[]
}

model Stock {
  id                String            @id @default(uuid())
  material          String
  espesor           Float?
  metrosDisponibles Float
  proveedor         String?
  costoMetro        Float?
  cantidadBobinas   Int?              @default(0)
  movimientos       MovimientoStock[]
}

model MovimientoStock {
  id        String   @id @default(uuid())
  tipo      String
  cantidad  Float
  fecha     DateTime @default(now())
  stockId   String?
  stockItem Stock?   @relation(fields: [stockId], references: [id], onDelete: SetNull)
}

model PedidoProveedor {
  id          String   @id @default(uuid())
  material    String
  fecha       DateTime @default(now())
  estado      String
  proveedorId String

  // Campos añadidos
  tipo                 String    @default("NACIONAL") // 'NACIONAL' o 'IMPORTACION'
  notas                String?
  numeroFactura        String?
  gastosTotales        Float     @default(0)
  tasaCambio           Float     @default(1)
  numeroContenedor     String?
  naviera              String?
  fechaLlegadaEstimada DateTime?

  proveedor Proveedor      @relation(fields: [proveedorId], references: [id])
  bobinas   BobinaPedido[]
}

model BobinaPedido {
  id       String          @id @default(uuid())
  cantidad Int             @default(1)
  pedidoId String
  pedido   PedidoProveedor @relation(fields: [pedidoId], references: [id], onDelete: Cascade)

  // Campos extendidos para detalle de bobina en pedido
  ancho       Float?
  largo       Float?
  espesor     Float?
  precioMetro Float  @default(0)

  // Relación con Referencia Maestro
  referenciaId String?
  referencia   ReferenciaBobina? @relation(fields: [referenciaId], references: [id])
}

model ReferenciaBobina {
  id                 String         @id @default(uuid())
  referencia         String
  ancho              Float?
  lonas              Float?
  pesoPorMetroLineal Float?
  bobinas            BobinaPedido[]

  @@unique([referencia, ancho, lonas]) // Constraint para evitar duplicados lógicos (opcional pero recomendado)
}

model ReglaMargen {
  id            String  @id @default(uuid())
  base          String  @unique
  multiplicador Float
  gastoFijo     Float?
  descripcion   String
  tierCliente   String?
}

model TarifaMaterial {
  id       String  @id @default(uuid())
  material String
  espesor  Float
  precio   Float
  peso     Float
  color    String? // "VERDE", "BLANCO", "AZUL", "NEGRO" para PVC, null para otros materiales

  @@unique([material, espesor, color])
}

model TarifaRollo {
  id            String  @id @default(uuid())
  material      String
  espesor       Float
  ancho         Float?  // mm, null = sin restricción de ancho
  color         String?
  metrajeMinimo Float   @default(10)
  precioBase    Float   // €/m²
  peso          Float   // kg/m²

  @@unique([material, espesor, color])
}

model Documento {
  id               String   @id @default(uuid())
  tipo             String
  referencia       String
  descripcion      String?
  rutaArchivo      String
  maquinaUbicacion String?
  fechaSubida      DateTime @default(now())
  productoId       String?

  producto Producto? @relation(fields: [productoId], references: [id], onDelete: SetNull)

  @@unique([referencia, rutaArchivo])
  @@map("Documento")
}

model Nota {
  id      String   @id @default(uuid())
  content String
  fecha   DateTime @default(now())
}

model Config {
  id    String @id @default(uuid())
  key   String @unique
  value String
}

model Sequence {
  name  String
  year  Int
  value Int

  @@id([name, year])
  @@map("Sequence")
}

model AuditLog {
  id        String   @id @default(uuid())
  action    String // CREATE, UPDATE, DELETE
  entity    String // Producto, Tarifa, Cliente, etc.
  entityId  String? // ID de la entidad afectada
  details   Json? // Detalles del cambio (anterior/nuevo)
  user      String? // Usuario que realizó la acción (o "System")
  createdAt DateTime @default(now())

  @@index([entity])
  @@index([action])
  @@index([createdAt])
  @@map("AuditLog")
}

model Producto {
  id                   String  @id @default(uuid())
  nombre               String
  referenciaFabricante String? @map("referencia_fab")
  espesor              Float?
  largo                Float?
  ancho                Float?
  precioUnitario       Float   @default(0)
  pesoUnitario         Float   @default(0)
  costoUnitario        Float?  @map("costo")
  tieneTroquel         Boolean @default(false)
  color                String?
  fabricanteId         String?
  materialId           String?

  // Precios calculados por tier
  precioVentaFab Float? @default(0)
  precioVentaInt Float? @default(0)
  precioVentaFin Float? @default(0)

  creadoEn    DateTime @default(now())
  actualizado DateTime @updatedAt

  // Relaciones
  fabricante Fabricante? @relation(fields: [fabricanteId], references: [id])
  material   Material?   @relation(fields: [materialId], references: [id])

  itemsPedido PedidoItem[]
  itemsPresup PresupuestoItem[]
  documentos  Documento[]

  @@index([nombre])
  @@index([fabricanteId])
  @@index([materialId])
}

model Taco {
  id          Int      @id @default(autoincrement())
  tipo        String // "RECTO" o "INCLINADO"
  altura      Int // 10, 20, 30, 40, 50, 60, 70, 80, 100
  precioMetro Float // Precio por metro lineal
  activo      Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@unique([tipo, altura])
}

model Grapa {
  id          Int      @id @default(autoincrement())
  nombre      String
  fabricante  String?
  descripcion String?
  precioMetro Float    @default(0)
  activo      Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model TarifaTransporte {
  id           String @id @default(uuid())
  provincia    String
  codigoPostal String
  parcel       Float?
  miniQuarter  Float?
  miniLight    Float?
  quarter      Float?
  light        Float?
  half         Float?
  megaLight    Float?
  full         Float?
  megaFull     Float?

  @@unique([provincia, codigoPostal])
  @@map("TarifaTransporte")
}

model ConfigPaletizado {
  id            String @id @default(uuid())
  tipo          String @unique // "EUROPEO" o "MEDIO"
  costePale     Float
  costeFilm     Float  @default(0.538) // 10% de 5.38€
  costeFleje    Float  @default(0.183) // 0.3% de 61€
  costePrecinto Float  @default(0.0147) // 1% de 1.47€

  @@map("ConfigPaletizado")
}

model PresupuestoTemplate {
  id          String   @id @default(uuid())
  nombre      String   @unique
  descripcion String?
  items       Json // Array de items guardados
  marginId    String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}
