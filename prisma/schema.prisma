generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Cliente {
  id           String         @id @default(uuid())
  nombre       String         @unique
  email        String?
  direccion    String?
  telefono     String?
  tier         String?
  categoria    String?
  pedidos      Pedido[]
  presupuestos Presupuesto[]
  // Relacionamos con la tabla antigua por si acaso
  productosOld Producto_Old[]
}

// Modelo antiguo mantenido solo para evitar perdida de datos historicos si fuera necesario
model Producto_Old {
  id                   String   @id @default(uuid())
  nombre               String
  referenciaFabricante String?  @map("referencia_fab")
  espesor              Float?
  largo                Float?
  ancho                Float?
  precioUnitario       Float
  pesoUnitario         Float
  costoUnitario        Float?   @map("costo")
  clienteId            String?
  cliente              Cliente? @relation(fields: [clienteId], references: [id])

  @@map("Producto_Old")
}

model Fabricante {
  id     String @id @default(uuid())
  nombre String @unique
}

model Material {
  id     String @id @default(uuid())
  nombre String @unique
}

model Pedido {
  id            String   @id @default(uuid())
  numero        String   @unique
  fechaCreacion DateTime @default(now())
  estado        String
  notas         String?
  subtotal      Float
  tax           Float
  total         Float
  clienteId     String?
  presupuestoId String?  @unique
  marginId      String?

  cliente     Cliente?     @relation(fields: [clienteId], references: [id])
  presupuesto Presupuesto? @relation(fields: [presupuestoId], references: [id])
  items       PedidoItem[]
}

model PedidoItem {
  id           String @id @default(uuid())
  descripcion  String
  quantity     Int
  unitPrice    Float
  pesoUnitario Float  @default(0)
  pedidoId     String

  // RELACION ACTUALIZADA AL NUEVO PRODUCTO
  productoId Int?
  pedido     Pedido    @relation(fields: [pedidoId], references: [id], onDelete: Cascade)
  producto   Producto? @relation(fields: [productoId], references: [id], onDelete: SetNull)
}

model Presupuesto {
  id            String   @id @default(uuid())
  numero        String   @unique
  fechaCreacion DateTime @default(now())
  estado        String
  notas         String?
  subtotal      Float
  tax           Float
  total         Float
  clienteId     String?
  marginId      String?

  cliente Cliente?          @relation(fields: [clienteId], references: [id])
  items   PresupuestoItem[]
  pedido  Pedido?
}

model PresupuestoItem {
  id            String @id @default(uuid())
  descripcion   String
  quantity      Int
  unitPrice     Float
  pesoUnitario  Float  @default(0)
  presupuestoId String

  // RELACION ACTUALIZADA AL NUEVO PRODUCTO
  productoId  Int?
  presupuesto Presupuesto @relation(fields: [presupuestoId], references: [id], onDelete: Cascade)
  producto    Producto?   @relation(fields: [productoId], references: [id], onDelete: SetNull)
}

model Proveedor {
  id        String            @id @default(uuid())
  nombre    String            @unique
  email     String?
  telefono  String?
  direccion String?
  pedidos   PedidoProveedor[]
}

model Stock {
  id                String            @id @default(uuid())
  material          String
  espesor           Float?
  metrosDisponibles Float
  proveedor         String?
  costoMetro        Float?
  cantidadBobinas   Int?              @default(0)
  movimientos       MovimientoStock[]
}

model MovimientoStock {
  id        String   @id @default(uuid())
  tipo      String
  cantidad  Float
  fecha     DateTime @default(now())
  stockId   String?
  stockItem Stock?   @relation(fields: [stockId], references: [id], onDelete: SetNull)
}

model PedidoProveedor {
  id          String   @id @default(uuid())
  material    String
  fecha       DateTime @default(now())
  estado      String
  proveedorId String

  // Campos añadidos
  tipo                 String    @default("NACIONAL") // 'NACIONAL' o 'IMPORTACION'
  notas                String?
  numeroFactura        String?
  gastosTotales        Float     @default(0)
  tasaCambio           Float     @default(1)
  numeroContenedor     String?
  naviera              String?
  fechaLlegadaEstimada DateTime?

  proveedor Proveedor      @relation(fields: [proveedorId], references: [id])
  bobinas   BobinaPedido[]
}

model BobinaPedido {
  id       String          @id @default(uuid())
  cantidad Int             @default(1)
  pedidoId String
  pedido   PedidoProveedor @relation(fields: [pedidoId], references: [id], onDelete: Cascade)

  // Campos extendidos para detalle de bobina en pedido
  ancho       Float?
  largo       Float?
  espesor     Float?
  precioMetro Float  @default(0)

  // Relación con Referencia Maestro
  referenciaId String?
  referencia   ReferenciaBobina? @relation(fields: [referenciaId], references: [id])
}

model ReferenciaBobina {
  id                 String         @id @default(uuid())
  referencia         String
  ancho              Float?
  lonas              Float?
  pesoPorMetroLineal Float?
  bobinas            BobinaPedido[]

  @@unique([referencia, ancho, lonas]) // Constraint para evitar duplicados lógicos (opcional pero recomendado)
}

model ReglaMargen {
  id            String  @id @default(uuid())
  base          String  @unique
  multiplicador Float
  gastoFijo     Float?
  descripcion   String
  tierCliente   String?
}

model TarifaMaterial {
  id       String @id @default(uuid())
  material String
  espesor  Float
  precio   Float
  peso     Float

  @@unique([material, espesor])
}

model Documento {
  id          String   @id @default(uuid())
  tipo        String
  referencia  String
  rutaArchivo String
  fechaSubida DateTime @default(now())

  // RELACION ACTUALIZADA AL NUEVO PRODUCTO
  productoId Int?
  producto   Producto? @relation(fields: [productoId], references: [id], onDelete: SetNull)

  @@unique([referencia, rutaArchivo])
  @@map("Documento")
}

model Nota {
  id      String   @id @default(uuid())
  content String
  fecha   DateTime @default(now())
}

model Config {
  id    String @id @default(uuid())
  key   String @unique
  value String
}

model Sequence {
  name  String @id
  value Int
}

model Producto {
  id          Int      @id @default(autoincrement())
  nombre      String
  descripcion String?
  // Usamos Decimal para dinero, precision 10, escala 2
  precio      Decimal  @db.Decimal(10, 2)
  stock       Int      @default(0)
  categoria   String?
  creadoEn    DateTime @default(now())
  actualizado DateTime @updatedAt

  // Relaciones Inversas
  itemsPedido PedidoItem[]
  itemsPresup PresupuestoItem[]
  documentos  Documento[]
}
